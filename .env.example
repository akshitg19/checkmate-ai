# Non-secret Vertex AI defaults. Export overrides in your shell when needed.
GOOGLE_CLOUD_PROJECT=cs-sail-2b08
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Optional frontend/backend overrides. The default Vite /api proxy works on
# tablets that open the frontend through the laptop's Network URL.
VITE_API_BASE_URL=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
